CPackConfig.cmake
CPackSourceConfig.cmake
compile_commands.json

# ─── VS Code ────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# ─── ARM Toolchain / Compiler Artifacts ─────────────────────────
*.o
*.d
*.su         # stack usage files
*.cyclo      # cyclomatric complexity (CubeIDE artifact, may appear)

# ─── OpenOCD / Debug ────────────────────────────────────────────
*.cfg.bak
openocd.log

# ─── STM32CubeMX ────────────
*.cproject
*.project
*.mxproject
STM32CubeMX/
.settings/*

# ─── OS Junk ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*~

# ─── Logs ───────────────────────────────────────────────────────
*.log